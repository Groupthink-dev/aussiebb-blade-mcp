# Aussie Broadband MyAussie portal credentials
ABB_USERNAME=your.email@example.com
ABB_PASSWORD=your-myaussie-password

# Enable line diagnostic tests (connection check, port reset, etc.)
# Disabled by default — diagnostics can briefly interrupt your connection
ABB_DIAGNOSTICS_ENABLED=false

# Transport: stdio (default) or http
ABB_MCP_TRANSPORT=stdio

# HTTP transport settings (only used when ABB_MCP_TRANSPORT=http)
ABB_MCP_HOST=127.0.0.1
ABB_MCP_PORT=8780
ABB_MCP_API_TOKEN=

# Logging level
ABB_LOG_LEVEL=WARNING
